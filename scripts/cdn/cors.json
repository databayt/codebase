{
  "CORSRules": [
    {
      "AllowedOrigins": [
        "https://cdn.databayt.org",
        "https://databayt.org",
        "https://*.databayt.org",
        "http://localhost:3000"
      ],
      "AllowedMethods": ["GET", "HEAD"],
      "AllowedHeaders": ["*"],
      "ExposeHeaders": [
        "Content-Length",
        "Content-Type",
        "ETag",
        "Cache-Control"
      ],
      "MaxAgeSeconds": 86400
    }
  ]
}
